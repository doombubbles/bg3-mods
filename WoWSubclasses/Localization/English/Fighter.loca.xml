  <content contentuid="h3cad98cbgcabbg4195ga960g794a652e070f" version="1">Does not go on cooldown.</content>


  <content contentuid="h7305e2c4ga13dg4b94g904cg9c04170f60de" version="1">Cooldown: Once per &lt;LSTag Tooltip="ShortRest"&gt;Short Rest&lt;/LSTag&gt;.</content>

