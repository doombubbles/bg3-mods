-- Invert the sort-order table to a 'key: index' map
-- (so you can input a key-name and get the index/sort-priority out)
for i, v in ipairs(__PropSortPriorities) do
  -- If an entry doesn't exist, fill it in (e.g. don't overwrite existing entries)
  if not __PropSortPriorities[v] then
    __PropSortPriorities[v] = i
  end
  -- Remove the original indexed entry
  __PropSortPriorities[i] = nil
end
