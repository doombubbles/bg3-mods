{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Go (Windows)",
      "type": "process",
      "command": "go",
      "args": [
        "build",
        "-o",
        "../../bin/ProcessTemplates.exe",
        "ProcessTemplates.go"
      ],
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "showReuseMessage": false,
        "revealProblems": "onProblem"
      },
      "options": {
        "cwd": "scripts/ProcessTemplates",
        "env": {
          "GOOS": "windows",
          "GOARCH": "amd64"
        }
      }
    },
    {
      "label": "Process Wiki",
      "type": "process",
      "command": "bin/ProcessTemplates.exe",
      "args": [
        "-s",
        "Wiki",
        "-d",
        "build/Wiki",
        "-v",
        "DoombubblesTweaks",
        "-v",
        "build/DoombubblesTweaks/Localization",
        "-v",
        "WoWDeathKnight",
        "-v",
        "build/WoWDeathKnight/Localization",
        "-v",
        "WoWSubclasses",
        "-v",
        "build/WoWSubclasses/Localization"
      ],
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "showReuseMessage": false,
        "revealProblems": "onProblem"
      }
    },
    {
      "label": "Clear Toolkit Folders",
      "type": "process",
      "command": "bin/busybox.exe",
      "args": ["bash", "scripts/clear.sh"],
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "showReuseMessage": false,
        "revealProblems": "onProblem"
      }
    },
    {
      "label": "Build Mod",
      "type": "process",
      "command": "bin/busybox.exe",
      "args": ["bash", "scripts/build.sh", "${input:mod}"],
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "showReuseMessage": false,
        "revealProblems": "onProblem"
      }
    },
    {
      "label": "Open Mod In Toolkit",
      "type": "process",
      "command": "C:/Program Files (x86)/Steam/steamapps/common/Baldurs Gate 3 Toolkit/Glasses.exe",
      "args": ["-project", "${input:mod}", "-lvl", "WLD_Campfire_E"],
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "showReuseMessage": false,
        "revealProblems": "onProblem"
      },
      "options": {
        "cwd": "C:/Program Files (x86)/Steam/steamapps/common/Baldurs Gate 3 Toolkit"
      },
      "dependsOn": ["Build Mod"],
      "dependsOrder": "sequence"
    }
  ],
  "inputs": [
    {
      "id": "mod",
      "type": "pickString",
      "description": "Which mod?",
      "options": [
        "DoombubblesTweaks",
        "WoWDeathKnight",
        "WoWSubclasses",
        "DoombubblesREL",
        "DoombubblesDifficulty"
      ]
    }
  ]
}
